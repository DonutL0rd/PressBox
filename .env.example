# TV-Automator Environment Variables
# Copy to .env and fill in your values.
#
# Runtime settings (favorites, overlays, etc.) are configured in the web UI
# and saved to $DATA_DIR/settings.json.
#
# Credentials set here take precedence over anything saved in the UI.

# ── MLB.TV ───────────────────────────────────────────────────────
# MLB_USERNAME=you@example.com
# MLB_PASSWORD=yourpassword

# ── Navidrome (music) ────────────────────────────────────────────
# NAVIDROME_URL=http://192.168.1.100:4533
# NAVIDROME_USERNAME=admin
# NAVIDROME_PASSWORD=yourpassword

# ── Display / browser ────────────────────────────────────────────
# DISPLAY=:0
# RESOLUTION=1920x1080
# CHROME_PATH=/usr/bin/google-chrome

# ── Data directory ───────────────────────────────────────────────
# DATA_DIR=/data
